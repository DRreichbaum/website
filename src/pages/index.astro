---
const year = new Date().getFullYear();
const CALENDLY = 'https://calendly.com/drreichbaum/30min';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="DR Consulting — Clean energy recruiting, career coaching, and professional networking. 15 years placing talent at SolarCity, Tesla, Rivian, and beyond." />
  <title>DR Consulting — Clean Energy Recruiting & Career Coaching</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Gloock&family=Source+Sans+3:opsz,wght@7..14,300..700&display=swap" rel="stylesheet" />
  <link href="https://assets.calendly.com/assets/external/widget.css" rel="stylesheet" />
</head>

<body>

  <!-- ═══ NAV ═══ -->
  <header class="site-nav" id="site-nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">DR Consulting</a>
      <button type="button" class="btn nav-cta js-cal">Book a call</button>
    </div>
  </header>

  <main>

    <!-- ═══ HERO ═══ -->
    <section class="hero" id="hero">
      <div class="hero-inner wrap">
        <div class="hero-preface" aria-hidden="true">
          <span class="hero-dash"></span>
          <span class="hero-label">Recruiting · Career Coaching · Clean Energy</span>
        </div>
        <h1 class="hero-headline">
          Connecting talent<br class="br-desktop" /> to the clean<br class="br-mobile" /> energy future.
        </h1>
        <p class="hero-sub">
          15 years placing engineers, executives, and operators at SolarCity,
          Tesla, Rivian, and beyond. Now helping the next wave find their
          place in it.
        </p>
        <button type="button" class="btn btn-accent btn-lg js-cal">Book a call</button>
      </div>
    </section>

    <!-- ═══ ABOUT ═══ -->
    <section class="about" id="about">
      <div class="about-inner wrap">
        <div class="about-copy">
          <h2 class="section-h">About David</h2>
          <p>
            I've spent 15 years inside the clean energy industry — not just
            recruiting for it. From the early days of residential solar at
            SolarCity to electric vehicles at Tesla and Rivian, to demand
            flexibility at Voltus and advisory work at Talisman Partners, I've
            been part of the teams building the infrastructure of the energy
            transition.
          </p>
          <p>
            That experience changes how I recruit. I know what a grid software
            engineer actually does on day one. I know what an operations leader
            at a storage company needs beyond the job description. I can have a
            real conversation with a candidate about why a role matters — and a
            real one with a hiring manager about what they actually need versus
            what they think they need.
          </p>
          <p>
            DR Consulting is my solo practice. I work with a small number of
            clients at a time, which means every search gets my full attention.
            If you're looking for a career conversation, a recruiting partnership,
            or a connection in the clean energy space — let's talk.
          </p>
        </div>
        <div class="about-mark" aria-hidden="true">
          <span class="about-initials">DR</span>
        </div>
      </div>
    </section>

    <!-- ═══ SERVICES ═══ -->
    <section class="services" id="services">
      <div class="wrap">
        <h2 class="section-h">What I do</h2>
        <div class="services-list">

          <article class="service">
            <h3 class="service-name">Clean Energy Recruiting</h3>
            <p class="service-body">
              Placing engineers, project developers, operators, and executives
              across solar, storage, EV, grid software, and sustainable
              infrastructure. Deep sector relationships and a 15-year track
              record across the full career lifecycle — from first cleantech
              role to C-suite placement.
            </p>
          </article>

          <article class="service">
            <h3 class="service-name">Career Coaching &amp; Transition</h3>
            <p class="service-body">
              For professionals navigating what's next — whether you're
              entering clean energy for the first time, considering a move
              within the sector, or planning a thoughtful exit into advisory
              work or retirement. 15 years of market knowledge and genuine
              industry relationships in every conversation.
            </p>
          </article>

          <article class="service">
            <h3 class="service-name">Recruiter Partnerships</h3>
            <p class="service-body">
              Partnering with internal TA teams and external search firms on
              specialized roles in adjacent verticals: robotics, AI/ML, data
              science, hard tech, deep tech, automation, and infrastructure.
              I bring sector depth; you bring the network. Together, we close
              faster and better.
            </p>
          </article>

        </div>
      </div>
    </section>

    <!-- ═══ WHO I WORK WITH ═══ -->
    <section class="clients" id="clients">
      <div class="wrap">
        <h2 class="section-h">Who I work with</h2>
        <ul class="clients-list">
          <li>
            <strong>Job seekers in clean energy &amp; climate tech</strong>
            — Mid-career professionals and senior leaders navigating a
            specialized, relationship-driven industry.
          </li>
          <li>
            <strong>Late-career professionals</strong>
            — Executives and senior contributors planning a thoughtful
            transition to advisory, board work, or retirement.
          </li>
          <li>
            <strong>Recruiters, internal and external</strong>
            — Talent professionals in adjacent verticals who need a
            specialist partner for cross-functional or hard-to-fill searches.
          </li>
          <li>
            <strong>University &amp; alumni career offices</strong>
            — Academic advisors connecting students and alumni with clean
            energy and climate tech opportunities.
          </li>
        </ul>
      </div>
    </section>

    <!-- ═══ CTA CLOSE ═══ -->
    <section class="cta-close">
      <div class="cta-close-inner wrap">
        <h2 class="cta-headline">Ready to connect?</h2>
        <p class="cta-sub">Every good placement starts with a conversation. Book 30 minutes.</p>
        <button type="button" class="btn btn-accent btn-lg js-cal">Book a call</button>
      </div>
    </section>

  </main>

  <!-- ═══ FOOTER ═══ -->
  <footer class="site-footer">
    <div class="footer-inner wrap">
      <span class="footer-name">DR Consulting</span>
      <span class="footer-copy">© {year} DR Consulting · Los Angeles, CA</span>
    </div>
  </footer>

  <script src="https://assets.calendly.com/assets/external/widget.js" type="text/javascript" async></script>

  <script is:inline>
    /* ── Enable CSS animations (guards against headless / no-JS) ── */
    document.documentElement.classList.add('js');

    /* ── Nav scroll state ── */
    (function () {
      var nav  = document.getElementById('site-nav');
      var hero = document.getElementById('hero');
      if (!nav || !hero) return;

      var io = new IntersectionObserver(function (entries) {
        nav.classList.toggle('is-scrolled', !entries[0].isIntersecting);
      }, { threshold: 0.06 });
      io.observe(hero);
    }());

    /* ── Calendly popup ── */
    function openCal() {
      if (typeof Calendly !== 'undefined') {
        Calendly.initPopupWidget({ url: 'https://calendly.com/drreichbaum/30min' });
      } else {
        window.open('https://calendly.com/drreichbaum/30min', '_blank', 'noopener,noreferrer');
      }
    }

    document.querySelectorAll('.js-cal').forEach(function (el) {
      el.addEventListener('click', openCal);
    });
  </script>

</body>
</html>

<style is:global>
/* ═════════════════════════════════════════════
   TOKENS
═════════════════════════════════════════════ */
:root {
  /* Brand */
  --c-primary:        oklch(0.35 0.095 165);
  --c-primary-dark:   oklch(0.26 0.080 165);
  --c-primary-hover:  oklch(0.41 0.095 165);
  --c-accent:         oklch(0.60 0.115 55);
  --c-accent-hover:   oklch(0.53 0.115 55);

  /* Surfaces */
  --c-bg:             oklch(1.000 0.000 0);
  --c-surface:        oklch(0.968 0.005 160);
  --c-rule:           oklch(0.888 0.008 160);

  /* Text */
  --c-ink:            oklch(0.20 0.018 165);
  --c-ink-on-dark:    oklch(0.96 0.006 160);
  --c-muted-on-dark:  oklch(0.76 0.018 165);

  /* Type */
  --f-display: 'Gloock', Georgia, serif;
  --f-body:    'Source Sans 3', system-ui, sans-serif;

  /* Scale — 1.333 perfect-fourth ratio, fluid for display */
  --t-xs:   clamp(0.75rem,  0.70rem + 0.25vw, 0.875rem);
  --t-sm:   clamp(0.875rem, 0.82rem + 0.28vw, 1rem);
  --t-base: 1.0625rem; /* 17px */
  --t-lg:   clamp(1.125rem, 1.05rem + 0.38vw, 1.333rem);
  --t-xl:   clamp(1.333rem, 1.20rem + 0.67vw, 1.777rem);
  --t-2xl:  clamp(1.777rem, 1.50rem + 1.40vw, 2.369rem);
  --t-3xl:  clamp(2.369rem, 1.90rem + 2.35vw, 3.157rem);
  --t-4xl:  clamp(3.157rem, 2.40rem + 3.80vw, 4.209rem);

  /* Spacing — 4pt base */
  --sp-1:  0.25rem;
  --sp-2:  0.5rem;
  --sp-3:  0.75rem;
  --sp-4:  1rem;
  --sp-5:  1.25rem;
  --sp-6:  1.5rem;
  --sp-8:  2rem;
  --sp-10: 2.5rem;
  --sp-12: 3rem;
  --sp-16: 4rem;
  --sp-20: 5rem;
  --sp-24: 6rem;
  --sp-32: 8rem;

  /* Layout */
  --max-w:   1100px;
  --pad-x:   clamp(1.5rem, 5vw, 4rem);
  --nav-h:   4rem;

  /* Motion */
  --dur-fast: 150ms;
  --dur-base: 250ms;
  --dur-slow: 400ms;
  --ease-out: cubic-bezier(0.16, 1, 0.3, 1);

  /* Z */
  --z-nav: 200;
}

/* ═════════════════════════════════════════════
   RESET
═════════════════════════════════════════════ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html {
  font-size: 100%;
  scroll-behavior: smooth;
  -webkit-text-size-adjust: 100%;
}

body {
  font-family: var(--f-body);
  font-size: var(--t-base);
  line-height: 1.65;
  color: var(--c-ink);
  background: var(--c-bg);
  -webkit-font-smoothing: antialiased;
  font-optical-sizing: auto;
}

img, svg { display: block; max-width: 100%; }
input, button, textarea, select { font: inherit; }
p { overflow-wrap: break-word; }

/* ═════════════════════════════════════════════
   LAYOUT UTILITY
═════════════════════════════════════════════ */
.wrap {
  max-width: var(--max-w);
  margin-inline: auto;
  padding-inline: var(--pad-x);
}

/* ═════════════════════════════════════════════
   BUTTONS
═════════════════════════════════════════════ */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0.65em 1.6em;
  border: none;
  border-radius: 3px;
  cursor: pointer;
  font-family: var(--f-body);
  font-size: var(--t-sm);
  font-weight: 600;
  letter-spacing: 0.01em;
  line-height: 1;
  text-decoration: none;
  transition:
    background var(--dur-fast) var(--ease-out),
    transform  var(--dur-fast) var(--ease-out);
}

.btn:active { transform: translateY(1px); }

.btn-accent {
  background: var(--c-accent);
  color: white;
}
.btn-accent:hover { background: var(--c-accent-hover); }

.btn-lg {
  padding: 0.8em 2.25em;
  font-size: var(--t-base);
}

:focus-visible {
  outline: 2.5px solid var(--c-accent);
  outline-offset: 3px;
}

/* ═════════════════════════════════════════════
   NAV
═════════════════════════════════════════════ */
.site-nav {
  position: fixed;
  inset-block-start: 0;
  inset-inline: 0;
  height: var(--nav-h);
  z-index: var(--z-nav);
  background: transparent;
  transition:
    background  var(--dur-base) var(--ease-out),
    box-shadow  var(--dur-base) var(--ease-out);
}

.site-nav.is-scrolled {
  background: var(--c-bg);
  box-shadow: 0 1px 0 var(--c-rule);
}

.nav-inner {
  max-width: var(--max-w);
  margin-inline: auto;
  padding-inline: var(--pad-x);
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.nav-logo {
  font-family: var(--f-display);
  font-size: var(--t-lg);
  color: var(--c-ink-on-dark);
  text-decoration: none;
  letter-spacing: -0.015em;
  transition: color var(--dur-base) var(--ease-out);
}

.site-nav.is-scrolled .nav-logo { color: var(--c-ink); }

/* Nav CTA: ghost on dark hero → solid on white */
.nav-cta {
  background: transparent;
  color: white;
  border: 1.5px solid rgba(255 255 255 / 0.45);
  padding: 0.5em 1.25em;
  font-size: var(--t-sm);
  border-radius: 3px;
  font-family: var(--f-body);
  font-weight: 600;
  cursor: pointer;
  transition:
    background   var(--dur-fast) var(--ease-out),
    border-color var(--dur-fast) var(--ease-out),
    color        var(--dur-base) var(--ease-out);
}

.nav-cta:hover {
  background: rgba(255 255 255 / 0.10);
  border-color: rgba(255 255 255 / 0.70);
}

.site-nav.is-scrolled .nav-cta {
  background: var(--c-primary);
  color: white;
  border-color: transparent;
}

.site-nav.is-scrolled .nav-cta:hover {
  background: var(--c-primary-hover);
}

/* ═════════════════════════════════════════════
   HERO
═════════════════════════════════════════════ */
.hero {
  background: var(--c-primary-dark);
  min-height: 100svh;
  display: flex;
  align-items: center;
  padding-block-start: var(--nav-h);
}

.hero-inner {
  padding-block: var(--sp-24);
}

/* Staggered entrance — gated by .js class so content is always
   visible by default (headless renderers, no-JS, backgrounded tabs) */
.js .hero-preface,
.js .hero-headline,
.js .hero-sub,
.js .hero-inner .btn {
  animation: fadeUp var(--dur-slow) var(--ease-out) both;
}

.js .hero-preface          { animation-delay: 60ms; }
.js .hero-headline         { animation-delay: 180ms; }
.js .hero-sub              { animation-delay: 320ms; }
.js .hero-inner .btn       { animation-delay: 450ms; }

@keyframes fadeUp {
  to { opacity: 1; transform: none; }
}

@media (prefers-reduced-motion: reduce) {
  .hero-preface,
  .hero-headline,
  .hero-sub,
  .hero-inner .btn {
    animation: none;
    opacity: 1;
    transform: none;
  }
}

.hero-preface {
  display: flex;
  align-items: center;
  gap: var(--sp-3);
  margin-bottom: var(--sp-8);
}

.hero-dash {
  display: block;
  width: 2rem;
  height: 1.5px;
  background: var(--c-accent);
  flex-shrink: 0;
}

.hero-label {
  font-family: var(--f-body);
  font-size: var(--t-sm);
  font-weight: 400;
  color: var(--c-muted-on-dark);
  letter-spacing: 0.03em;
}

.hero-headline {
  font-family: var(--f-display);
  font-size: var(--t-4xl);
  color: var(--c-ink-on-dark);
  line-height: 1.08;
  letter-spacing: -0.025em;
  text-wrap: balance;
  margin-bottom: var(--sp-6);
}

/* responsive line break helpers */
.br-mobile  { display: none; }
.br-desktop { display: block; }

@media (max-width: 480px) {
  .br-mobile  { display: block; }
  .br-desktop { display: none; }
}

.hero-sub {
  font-size: var(--t-lg);
  color: var(--c-muted-on-dark);
  font-weight: 300;
  line-height: 1.6;
  max-width: 52ch;
  margin-bottom: var(--sp-10);
}

/* ═════════════════════════════════════════════
   SECTION HEADING
═════════════════════════════════════════════ */
.section-h {
  font-family: var(--f-display);
  font-size: var(--t-2xl);
  color: var(--c-ink);
  letter-spacing: -0.02em;
  line-height: 1.15;
  text-wrap: balance;
  margin-bottom: var(--sp-12);
}

/* ═════════════════════════════════════════════
   ABOUT
═════════════════════════════════════════════ */
.about {
  padding-block: var(--sp-24) var(--sp-32);
  background: var(--c-bg);
}

.about-inner {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--sp-16);
}

@media (min-width: 768px) {
  .about-inner {
    grid-template-columns: 3fr 2fr;
    align-items: start;
  }
}

.about-copy p {
  color: var(--c-ink);
  line-height: 1.7;
  max-width: 64ch;
  margin-bottom: var(--sp-6);
}

.about-copy p:last-of-type { margin-bottom: 0; }

.about-mark {
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding-block-start: var(--sp-12);
}

@media (min-width: 768px) {
  .about-mark {
    justify-content: flex-end;
    padding-block-start: var(--sp-16);
  }
}

.about-initials {
  font-family: var(--f-display);
  font-size: clamp(5.5rem, 13vw, 9rem);
  line-height: 1;
  letter-spacing: -0.04em;
  color: transparent;
  -webkit-text-stroke: 1.5px var(--c-primary);
  text-stroke: 1.5px var(--c-primary);
  user-select: none;
  display: block;
}

/* ═════════════════════════════════════════════
   SERVICES
═════════════════════════════════════════════ */
.services {
  padding-block: var(--sp-24);
  background: var(--c-surface);
}

.services-list { margin-top: 0; }

.service {
  padding-block: var(--sp-10);
  border-top: 1px solid var(--c-rule);
}

.service:last-child {
  border-bottom: 1px solid var(--c-rule);
}

@media (min-width: 640px) {
  .service {
    display: grid;
    grid-template-columns: minmax(13rem, 21rem) 1fr;
    gap: var(--sp-8);
    align-items: baseline;
  }
}

.service-name {
  font-family: var(--f-display);
  font-size: var(--t-xl);
  color: var(--c-ink);
  letter-spacing: -0.015em;
  line-height: 1.2;
  text-wrap: balance;
  margin-bottom: var(--sp-3);
}

@media (min-width: 640px) {
  .service-name { margin-bottom: 0; }
}

.service-body {
  color: var(--c-ink);
  font-size: var(--t-base);
  line-height: 1.7;
  max-width: 60ch;
}

/* ═════════════════════════════════════════════
   WHO I WORK WITH
═════════════════════════════════════════════ */
.clients {
  padding-block: var(--sp-24);
  background: var(--c-bg);
}

.clients-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: var(--sp-8);
  max-width: 740px;
}

.clients-list li {
  padding-inline-start: var(--sp-6);
  position: relative;
  font-size: var(--t-base);
  color: var(--c-ink);
  line-height: 1.65;
}

.clients-list li::before {
  content: '';
  position: absolute;
  inset-inline-start: 0;
  top: 0.68em;
  width: 0.875rem;
  height: 1.5px;
  background: var(--c-accent);
}

.clients-list strong {
  font-weight: 600;
  color: var(--c-ink);
}

/* ═════════════════════════════════════════════
   CTA CLOSE
═════════════════════════════════════════════ */
.cta-close {
  background: var(--c-primary-dark);
  padding-block: var(--sp-24);
}

.cta-close-inner {
  text-align: center;
}

.cta-headline {
  font-family: var(--f-display);
  font-size: var(--t-3xl);
  color: var(--c-ink-on-dark);
  letter-spacing: -0.025em;
  line-height: 1.1;
  text-wrap: balance;
  margin-bottom: var(--sp-4);
}

.cta-sub {
  font-size: var(--t-lg);
  color: var(--c-muted-on-dark);
  font-weight: 300;
  line-height: 1.55;
  max-width: 44ch;
  margin-inline: auto;
  margin-bottom: var(--sp-10);
}

/* ═════════════════════════════════════════════
   FOOTER
═════════════════════════════════════════════ */
.site-footer {
  background: var(--c-primary-dark);
  border-top: 1px solid oklch(0.32 0.080 165);
  padding-block: var(--sp-8);
}

.footer-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: var(--sp-2);
}

.footer-name {
  font-family: var(--f-display);
  font-size: var(--t-sm);
  color: var(--c-muted-on-dark);
}

.footer-copy {
  font-size: var(--t-xs);
  color: oklch(0.62 0.010 165);
}
</style>
